# ── Backend (apps/api) ──
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Database (Supabase PostgreSQL)
DATABASE_URL=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Token encryption (32+ characters)
TOKEN_ENCRYPTION_KEY=

# YouTube (optional — public API key for channel stats, also used by YouTube Music)
YOUTUBE_API_KEY=

# Instagram OAuth (optional — requires Facebook App)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# TikTok OAuth (optional — requires TikTok Developer App)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Spotify (optional — client credentials for artist stats)
# Get yours at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Social Blade (optional — for extended historical metrics)
SOCIALBLADE_CLIENT_ID=
SOCIALBLADE_TOKEN=

# ── Frontend (apps/web) ──
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
